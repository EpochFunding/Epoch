# Model access
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Funding thresholds
EXTREME_RATE_THRESHOLD=0.01    # flag rates above 1% hourly (87.6% annualized)
ALERT_MIN_CONFIDENCE=0.65
